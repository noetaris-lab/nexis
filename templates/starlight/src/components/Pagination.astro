---
// nexis wiki — Pagination override.
//
// Starlight's default Prev/Next pager shows only the page title, so two pages
// that share a title in different sections (e.g. every "Overview") are
// indistinguishable. This override prints the page's section (its top-level
// sidebar group label) in a small caption above the title to disambiguate.
import { Icon } from '@astrojs/starlight/components';

const { dir, pagination, sidebar } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
const isRtl = dir === 'rtl';

/** Top-level sidebar group label containing `href`, or undefined if top-level. */
function sectionFor(href) {
  if (!href) return undefined;
  const norm = (h) => h.replace(/\/+$/, '');
  const target = norm(href);
  const contains = (entries) =>
    entries.some((e) =>
      e.type === 'link' ? norm(e.href) === target : contains(e.entries)
    );
  for (const entry of sidebar) {
    if (entry.type === 'group' && contains(entry.entries)) return entry.label;
  }
  return undefined;
}

const prevSection = sectionFor(prev?.href);
const nextSection = sectionFor(next?.href);
---

<div class="pagination-links print:hidden" dir={dir}>
  {
    prev && (
      <a href={prev.href} rel="prev">
        <Icon name={isRtl ? 'right-arrow' : 'left-arrow'} size="1.5rem" />
        <span>
          {Astro.locals.t('page.previousLink')}
          {prevSection && <span class="link-section">{prevSection}</span>}
          <span class="link-title">{prev.label}</span>
        </span>
      </a>
    )
  }
  {
    next && (
      <a href={next.href} rel="next">
        <Icon name={isRtl ? 'left-arrow' : 'right-arrow'} size="1.5rem" />
        <span>
          {Astro.locals.t('page.nextLink')}
          {nextSection && <span class="link-section">{nextSection}</span>}
          <span class="link-title">{next.label}</span>
        </span>
      </a>
    )
  }
</div>

<style>
  .pagination-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 1rem;
  }

  a {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    width: 100%;
    flex-basis: calc(50% - 0.5rem);
    flex-grow: 1;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 1rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    box-shadow: var(--sl-shadow-md);
    overflow-wrap: anywhere;
  }
  [rel='next'] {
    justify-content: end;
    text-align: end;
    flex-direction: row-reverse;
  }
  a:hover {
    border-color: var(--sl-color-gray-2);
  }

  a > span {
    display: flex;
    flex-direction: column;
  }

  .link-section {
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
  }

  .link-title {
    color: var(--sl-color-white);
    font-size: var(--sl-text-2xl);
    line-height: var(--sl-line-height-headings);
  }

  svg {
    flex-shrink: 0;
  }
</style>
